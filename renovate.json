{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "labels": ["dependencies"],

  "forkProcessing": "enabled",

  "bundler": {
    "enabled": true,
    "fileMatch": ["^Gemfile$", "^Gemfile.lock$"]
  },

  "docker": {
    "enabled": true,
    "pinDigests": true
  },

  "github-actions": {
    "enabled": true,
    "pinDigests": true
  },

  "lockFileMaintenance": {
    "enabled": true
  },

  "prConcurrentLimit": 10,
  "prHourlyLimit": 0
}
